# Jawafdehi MCP Server Configuration

# Base URL for Jawafdehi API (defaults to https://portal.jawafdehi.org)
JAWAFDEHI_API_BASE_URL=https://portal.jawafdehi.org

# Token for authenticated Jawafdehi API write operations such as NES queue
# submissions. Generate via Jawafdehi API, e.g.:
# poetry run python manage.py drf_create_token <username>
JAWAFDEHI_API_TOKEN=your_jawafdehi_api_token

# NES API Configuration (Default: https://nes.jawafdehi.org)
NES_API_BASE_URL=https://nes.jawafdehi.org

# OCR Configuration for markitdown-likhit / markitdown-ocr
# Use either an OpenAI-compatible provider or Gemini.

# Required for OCR when using an OpenAI-compatible provider
OPENAI_API_KEY=your_openai_compatible_api_key

# Optional custom base URL for OpenAI-compatible providers
# OPENAI_BASE_URL=https://your-provider.example/v1/

# Required OCR model name
MARKITDOWN_OCR_MODEL=gpt-4.1-mini

# Optional custom OCR prompt
# MARKITDOWN_OCR_PROMPT=Extract Nepali text faithfully and preserve table structure.

# Gemini alternative (uses Gemini's OpenAI-compatible endpoint)
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.5-flash
