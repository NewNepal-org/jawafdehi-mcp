# Jawafdehi MCP Server Configuration

# Base URL for Jawafdehi API (defaults to https://portal.jawafdehi.org)
JAWAFDEHI_API_BASE_URL=https://portal.jawafdehi.org

# Token for authenticated Jawafdehi API write operations such as NES queue
# submissions. Generate via Jawafdehi API, e.g.:
# poetry run python manage.py drf_create_token <username>
JAWAFDEHI_API_TOKEN=your_jawafdehi_api_token

# NGM Database Connection (Required)
# PostgreSQL connection string for Nepal Governance Modernization database
NGM_DATABASE_URL=postgresql://user:password@host:5432/database_name

# Example for local development:
# NGM_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ngm

# Example for production:
# NGM_DATABASE_URL=postgresql://user:pass@db.example.com:5432/ngm_prod

# NES API Configuration (Default: https://nes.newnepal.org)
NES_API_BASE_URL=https://nes.newnepal.org
